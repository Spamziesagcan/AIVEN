# LLM provider
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App config
APP_ENV=development
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Storage
DATABASE_URL=
OLLIVE_DB_PATH=/data/ollive.sqlite3

# Optional runtime settings
REDIS_URL=
LLM_REQUEST_LOG_PATH=
OLLIVE_EVENT_PROCESS_INLINE=true